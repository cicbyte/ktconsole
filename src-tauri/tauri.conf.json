{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KineticConsole",
  "version": "0.1.0",
  "identifier": "com.kinetic-console.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kinetic Console",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Kinetic Console - Port Forwarding Manager",
    "longDescription": "桌面端口转发和隧道管理工具，支持 ngrok、cpolar 等隧道服务提供商",
    "category": "DeveloperTool"
  }
}
